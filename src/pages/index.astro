---
import manifest from "../manifest.json";
const { categorias, graficas } = manifest as {
  categorias: Record<string, { label: string; color: string }>;
  graficas: any[];
};
const base = import.meta.env.BASE_URL;
// une base + ruta con EXACTAMENTE una barra (el base puede o no terminar en "/")
const u = (p: string) => `${base.replace(/\/$/, "")}/${p.replace(/^\//, "")}`;
const cats = Object.entries(categorias);
const updated = new Date().toISOString().slice(0, 10);
const nMapas = graficas.filter((g) => g.tipo === "mapa").length;
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- Fija el tema ANTES de pintar (evita parpadeo): localStorage o preferencia del sistema -->
  <script is:inline>
    (function () {
      try {
        var p = new URLSearchParams(location.search).get('tema');
        var t = (p === 'dark' || p === 'light') ? p : localStorage.getItem('tema');
        if (t !== 'dark' && t !== 'light')
          t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', t);
      } catch (e) { document.documentElement.setAttribute('data-theme', 'light'); }
    })();
  </script>
  <title>Banco de Gráficos · Centro de Estudios POPULI</title>
  <meta name="description" content="Gráficas e indicadores de Bolivia con fuente verificada, en alta resolución y listos para compartir. Centro de Estudios POPULI." />
  <meta property="og:title" content="Banco de Gráficos · POPULI" />
  <meta property="og:description" content="Gráficas e indicadores de Bolivia, listos para descargar y compartir." />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='85' font-family='serif' font-weight='700' fill='%238B1A1A'>P</text></svg>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Public+Sans:wght@400;500;600;700&family=Zilla+Slab:wght@600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- ===== HERO (estilo monitor: oscuro + partículas) ===== -->
  <header class="hero">
    <canvas id="particles" aria-hidden="true"></canvas>
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>

    <div class="hero-inner">
      <div class="wm-row">
        <span class="wordmark"><span class="wm-p">P</span><span class="wm-rest">opuli</span></span>
        <a class="back" href="https://populi.org.bo">populi.org.bo ↗</a>
      </div>

      <span class="eyebrow"><span class="diamond"></span> Gráficos abiertos · Bolivia</span>
      <h1>Banco de <span class="ital">Gráficos</span></h1>
      <p>Gráficas e indicadores de Bolivia con fuente verificada. Busca, previsualiza y descarga
         la imagen <strong>en alta resolución, lista para compartir</strong>.</p>

      <div class="stats">
        <span><b>{graficas.length}</b> gráficas</span>
        <span class="sep"></span>
        <span><b>{nMapas}</b> mapas municipales</span>
        <span class="sep"></span>
        <span><b>339</b> municipios</span>
        <span class="sep"></span>
        <span>alta resolución</span>
      </div>
    </div>
    <div class="hero-fade" aria-hidden="true"></div>
  </header>

  <!-- ===== CONTROLES ===== -->
  <div class="controls">
    <div class="ctl-row">
      <input id="search" type="search" placeholder="Buscar por tema, indicador, fuente o etiqueta…" autocomplete="off" />
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Cambiar tema claro/oscuro" title="Cambiar tema">
        <svg class="i-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/></svg>
        <svg class="i-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4.2"/><path d="M12 2.5v2.5M12 19v2.5M2.5 12H5M19 12h2.5M4.8 4.8l1.8 1.8M17.4 17.4l1.8 1.8M19.2 4.8l-1.8 1.8M6.6 17.4l-1.8 1.8"/></svg>
      </button>
    </div>
    <div class="chips" id="chips">
      <button class="chip active" data-cat="*">Todas <span class="n">{graficas.length}</span></button>
      {cats.map(([k, c]) => (
        <button class="chip" data-cat={k} style={`--c:${c.color}`}>{c.label}</button>
      ))}
    </div>
  </div>

  <!-- ===== GRILLA ===== -->
  <main id="grid" class="grid">
    {graficas.map((it) => {
      const c = categorias[it.categoria] ?? { label: it.categoria, color: "#8B1A1A" };
      const haystack = `${it.titulo} ${it.subtitulo ?? ""} ${it.fuente ?? ""} ${(it.tags ?? []).join(" ")} ${c.label}`.toLowerCase();
      return (
        <article class="card" data-cat={it.categoria} data-haystack={haystack}>
          <button class="thumb" data-full={u(it.imagen)} data-title={it.titulo} aria-label={`Ampliar ${it.titulo}`}>
            <img src={u(it.thumb)} alt={it.titulo} loading="lazy" width="540" height="540" />
            <span class="cat-chip" style={`background:${c.color}`}>{c.label}</span>
          </button>
          <div class="meta">
            <h3>{it.titulo}</h3>
            <p class="src">{it.fuente}{it.fecha ? ` · ${it.fecha}` : ""}</p>
            <div class="acc">
              <a class="dl png" href={u(it.imagen)} download={`${it.slug}.png`}>↓ Descargar imagen</a>
            </div>
          </div>
        </article>
      );
    })}
  </main>
  <p id="empty" class="empty" hidden>No se encontraron gráficas para tu búsqueda.</p>

  <footer class="foot">
    <span><span class="wm-p">P</span>opuli · Banco de Gráficos</span>
    <span>{graficas.length} gráficas · actualizado {updated} · <a href="https://populi.org.bo">populi.org.bo</a></span>
  </footer>

  <div id="lb" class="lb" hidden>
    <button class="lb-close" aria-label="Cerrar">✕</button>
    <figure>
      <img id="lb-img" src="" alt="" />
      <figcaption><a id="lb-dl" href="" download>Descargar en alta calidad ↓</a></figcaption>
    </figure>
  </div>

  <script>
    const search = document.getElementById('search') as HTMLInputElement;
    const cards = [...document.querySelectorAll('.card')] as HTMLElement[];
    const chips = [...document.querySelectorAll('.chip')] as HTMLElement[];
    const empty = document.getElementById('empty')!;
    let activeCat = '*';
    function apply() {
      const q = search.value.trim().toLowerCase();
      let shown = 0;
      cards.forEach((c) => {
        const okCat = activeCat === '*' || c.dataset.cat === activeCat;
        const okText = !q || (c.dataset.haystack ?? '').includes(q);
        const vis = okCat && okText; c.hidden = !vis; if (vis) shown++;
      });
      (empty as HTMLElement).hidden = shown > 0;
    }
    search.addEventListener('input', apply);
    chips.forEach((ch) => ch.addEventListener('click', () => {
      chips.forEach((x) => x.classList.remove('active'));
      ch.classList.add('active'); activeCat = ch.dataset.cat!; apply();
    }));
    const lb = document.getElementById('lb')!;
    const lbImg = document.getElementById('lb-img') as HTMLImageElement;
    const lbDl = document.getElementById('lb-dl') as HTMLAnchorElement;
    document.querySelectorAll('.thumb').forEach((t) => t.addEventListener('click', () => {
      const el = t as HTMLElement;
      lbImg.src = el.dataset.full!; lbImg.alt = el.dataset.title!; lbDl.href = el.dataset.full!;
      (lb as HTMLElement).hidden = false; document.body.style.overflow = 'hidden';
    }));
    function closeLb() { (lb as HTMLElement).hidden = true; document.body.style.overflow = ''; }
    lb.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (t === lb || t.classList.contains('lb-close')) closeLb();
    });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLb(); });

    // ----- tema claro/oscuro -----
    const toggle = document.getElementById('theme-toggle')!;
    toggle.addEventListener('click', () => {
      const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('tema', next); } catch (e) {}
    });
  </script>

  <!-- Partículas del hero (constellation network, estilo monitores POPULI) -->
  <script is:inline>
    (function () {
      const canvas = document.getElementById('particles');
      if (!canvas) return;
      const host = canvas.parentElement, ctx = canvas.getContext('2d');
      const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const RGB = '255,255,255', ACC = '212,160,23', CONNECT = 140, MR = 170;
      let w = 0, h = 0, parts = [], raf = 0; const mouse = { x: -9999, y: -9999 };
      function resize() {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        w = host.offsetWidth; h = host.offsetHeight;
        canvas.width = Math.round(w * dpr); canvas.height = Math.round(h * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }
      function make() {
        const n = w < 768 ? 30 : 64; parts = [];
        for (let i = 0; i < n; i++) {
          const b = Math.random() * 0.35 + 0.12;
          parts.push({ x: Math.random() * w, y: Math.random() * h, vx: (Math.random() - .5) * .4,
            vy: (Math.random() - .5) * .4, r: Math.random() * 1.8 + .8, base: b, alpha: b, gold: Math.random() < .18 });
        }
      }
      function frame() {
        ctx.clearRect(0, 0, w, h);
        for (let i = 0; i < parts.length; i++) {
          const p = parts[i], dx = mouse.x - p.x, dy = mouse.y - p.y, dist = Math.hypot(dx, dy);
          if (dist < MR) { const f = ((MR - dist) / MR) * 0.008; p.vx += dx * f; p.vy += dy * f; p.alpha = p.base + (1 - dist / MR) * 0.4; }
          else { p.alpha += (p.base - p.alpha) * 0.02; }
          p.vx *= 0.99; p.vy *= 0.99; p.x += p.vx; p.y += p.vy;
          if (p.x < 0) p.x = w; if (p.x > w) p.x = 0; if (p.y < 0) p.y = h; if (p.y > h) p.y = 0;
          ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(' + (p.gold ? ACC : RGB) + ',' + p.alpha + ')'; ctx.fill();
          for (let j = i + 1; j < parts.length; j++) {
            const p2 = parts[j], d = Math.hypot(p.x - p2.x, p.y - p2.y);
            if (d < CONNECT) {
              let la = (1 - d / CONNECT) * 0.13;
              const mx = (p.x + p2.x) / 2, my = (p.y + p2.y) / 2, md = Math.hypot(mouse.x - mx, mouse.y - my);
              if (md < MR) la += (1 - md / MR) * 0.13;
              ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(p2.x, p2.y);
              ctx.strokeStyle = 'rgba(' + RGB + ',' + la + ')'; ctx.lineWidth = 0.6; ctx.stroke();
            }
          }
        }
        raf = requestAnimationFrame(frame);
      }
      resize(); make();
      if (reduce) { for (const p of parts) { ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2); ctx.fillStyle = 'rgba(' + (p.gold ? ACC : RGB) + ',' + p.base + ')'; ctx.fill(); } }
      else { raf = requestAnimationFrame(frame); }
      host.addEventListener('mousemove', (e) => { const r = canvas.getBoundingClientRect(); mouse.x = e.clientX - r.left; mouse.y = e.clientY - r.top; });
      host.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });
      window.addEventListener('resize', () => { resize(); make(); });
    })();
  </script>
</body>
</html>

<style is:global>
  :root {
    --populi: #8B1A1A; --populi-dark: #6B0300; --gold: #D4A017;
    --navy: #0D1B2A; --navy2: #1A2940; --ink: #2B2420; --cafe: #5C3D1E; --muted: #8C8378;
    --warm-white: #FAF8F3; --panel: #F1EDE5; --border: #E2DDD3; --card: #ffffff;
    --chip-text: var(--cafe);
  }
  /* ---------- TEMA OSCURO (toda la galería combina; el hero ya es oscuro) ---------- */
  html[data-theme="dark"] {
    --ink: #ECE7DD; --cafe: #C9BCA8; --muted: #97A1AE; --chip-text: #C9D2DD;
    --warm-white: #0E1521; --panel: #141D29; --border: #2A3543; --card: #18222F;
    --populi: #C8443B;          /* rojo un poco más claro para legibilidad sobre oscuro */
    --populi-dark: #A8342C;
  }
  html { background: var(--warm-white); }
  * { box-sizing: border-box; }
  body {
    margin: 0; background: var(--warm-white); color: var(--ink);
    font-family: 'Public Sans', system-ui, sans-serif; -webkit-font-smoothing: antialiased;
    transition: background .25s ease, color .25s ease;
  }
  a { color: var(--populi); }
  .wm-p { font-family: 'Playfair Display', Georgia, serif; font-weight: 700; color: var(--populi); }
  .wm-rest { font-family: 'Playfair Display', Georgia, serif; font-style: italic; color: var(--ink); }

  /* ---------- HERO ---------- */
  .hero {
    position: relative; overflow: hidden; color: #fff;
    background: radial-gradient(1200px 500px at 78% -8%, rgba(139,26,26,.55), transparent 60%),
                linear-gradient(160deg, #122236 0%, var(--navy) 45%, #0a1422 100%);
    border-top: 4px solid var(--populi);
  }
  #particles { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }
  .hero-grid {
    position: absolute; inset: 0; z-index: 0; opacity: .05; pointer-events: none;
    background-image: linear-gradient(rgba(255,255,255,.6) 1px, transparent 1px),
                      linear-gradient(90deg, rgba(255,255,255,.6) 1px, transparent 1px);
    background-size: 64px 64px;
  }
  .hero-glow { position: absolute; left: -8%; bottom: -40%; width: 520px; height: 520px; z-index: 0;
    background: radial-gradient(circle, rgba(212,160,23,.12), transparent 70%); pointer-events: none; }
  .hero-inner { position: relative; z-index: 10; max-width: 1180px; margin: 0 auto; padding: 30px 24px 84px; }
  .wm-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 40px; }
  .wm-row .wm-p { color: #fff; } .wm-row .wm-rest { color: rgba(255,255,255,.92); }
  .wm-row .wordmark { font-size: 28px; }
  .wm-row .back { color: rgba(255,255,255,.6); text-decoration: none; font-size: 13px; font-weight: 600; }
  .wm-row .back:hover { color: var(--gold); }
  .eyebrow { display: inline-flex; align-items: center; gap: 10px; font-size: 12px; font-weight: 600;
    letter-spacing: .22em; text-transform: uppercase; color: var(--gold); }
  .eyebrow .diamond { width: 8px; height: 8px; background: var(--gold); transform: rotate(45deg); }
  .hero h1 { font-family: 'Zilla Slab', Georgia, serif; font-weight: 700; color: #fff;
    font-size: clamp(40px, 7vw, 76px); line-height: 1.04; letter-spacing: -.01em; margin: 16px 0 0; }
  .hero h1 .ital { color: var(--gold); }
  .hero p { color: rgba(255,255,255,.78); font-size: clamp(16px, 2.1vw, 20px); line-height: 1.55;
    max-width: 660px; margin: 20px 0 0; }
  .hero p strong { color: #fff; font-weight: 600; }
  .hero .stats { display: flex; flex-wrap: wrap; align-items: center; gap: 14px; margin-top: 34px;
    font-size: 14px; color: rgba(255,255,255,.7); }
  .hero .stats b { color: #fff; font-weight: 700; font-size: 18px; }
  .hero .stats .sep { width: 1px; height: 16px; background: rgba(255,255,255,.25); }
  .hero-fade { position: absolute; left: 0; right: 0; bottom: 0; height: 64px; z-index: 5;
    background: linear-gradient(transparent, var(--warm-white)); pointer-events: none; }

  /* ---------- CONTROLES ---------- */
  .controls { max-width: 1180px; margin: 0 auto; padding: 26px 24px 0; position: sticky; top: 0;
    background: var(--warm-white); z-index: 20; }
  .ctl-row { display: flex; gap: 12px; align-items: stretch; }
  #search { flex: 1; min-width: 0; padding: 14px 18px; font-size: 16px; font-family: inherit;
    color: var(--ink); border: 2px solid var(--border); border-radius: 12px; background: var(--card); outline: none; }
  #search:focus { border-color: var(--populi); }
  #search::placeholder { color: var(--muted); }
  .theme-toggle { flex: 0 0 auto; width: 52px; display: grid; place-items: center; cursor: pointer;
    border: 2px solid var(--border); border-radius: 12px; background: var(--card); color: var(--ink);
    transition: border-color .15s, color .15s, background .25s; }
  .theme-toggle:hover { border-color: var(--populi); color: var(--populi); }
  .theme-toggle svg { width: 20px; height: 20px; }
  .theme-toggle .i-sun { display: none; }
  html[data-theme="dark"] .theme-toggle .i-moon { display: none; }
  html[data-theme="dark"] .theme-toggle .i-sun { display: block; }
  .chips { display: flex; flex-wrap: wrap; gap: 8px; padding: 14px 0 18px; }
  .chip { --c: var(--populi); border: 1.5px solid var(--border); background: var(--card); color: var(--chip-text);
    padding: 7px 15px; border-radius: 999px; font-size: 14px; font-weight: 600; cursor: pointer;
    font-family: inherit; transition: all .15s; }
  .chip:hover { border-color: var(--c); color: var(--c); }
  .chip.active { background: var(--c); border-color: var(--c); color: #fff; }
  .chip .n { opacity: .7; font-variant-numeric: tabular-nums; }

  /* ---------- GRILLA ---------- */
  .grid { max-width: 1180px; margin: 0 auto; padding: 8px 24px 48px;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 24px; }
  .card { display: flex; flex-direction: column; }
  .card[hidden] { display: none; }
  .thumb { position: relative; border: 1px solid var(--border); padding: 0; cursor: zoom-in; background: var(--card);
    border-radius: 14px; overflow: hidden; box-shadow: 0 1px 3px rgba(20,20,20,.06);
    transition: transform .18s, box-shadow .18s; aspect-ratio: 1; display: block; }
  .thumb:hover { transform: translateY(-3px); box-shadow: 0 12px 30px rgba(0,0,0,.45); }
  .thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cat-chip { position: absolute; top: 10px; left: 10px; color: #fff; font-size: 11px; font-weight: 600;
    letter-spacing: .3px; padding: 4px 10px; border-radius: 999px; }
  .meta { padding: 13px 4px 0; }
  .meta h3 { font-size: 16px; line-height: 1.3; margin: 0 0 4px; font-weight: 700; }
  .meta .src { font-size: 12.5px; color: var(--muted); margin: 0 0 11px; }
  .acc { display: flex; gap: 8px; }
  .dl { display: inline-flex; align-items: center; justify-content: center; gap: 6px; text-decoration: none;
    font-size: 13px; font-weight: 600; padding: 8px 13px; border-radius: 9px; transition: all .15s; }
  .dl.png { flex: 1; background: var(--populi); color: #fff; } .dl.png:hover { background: var(--populi-dark); }

  .empty { text-align: center; color: var(--muted); padding: 40px; max-width: 1180px; margin: 0 auto; }
  .foot { border-top: 1px solid var(--border); padding: 24px; display: flex; justify-content: space-between;
    flex-wrap: wrap; gap: 8px; font-size: 13px; color: var(--muted); max-width: 1180px; margin: 0 auto; }
  .foot .wm-p { font-size: 16px; }

  .lb { position: fixed; inset: 0; background: rgba(13,27,42,.92); z-index: 50; display: flex;
    align-items: center; justify-content: center; padding: 24px; }
  .lb[hidden] { display: none; }
  .lb figure { margin: 0; max-width: min(92vw, 720px); text-align: center; }
  .lb img { max-width: 100%; max-height: 80vh; border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,.5); }
  .lb figcaption { margin-top: 16px; }
  .lb-dl { display: inline-block; background: var(--populi); color: #fff; text-decoration: none;
    padding: 11px 22px; border-radius: 10px; font-weight: 600; }
  .lb-close { position: absolute; top: 18px; right: 22px; background: none; border: 0; color: #fff;
    font-size: 28px; cursor: pointer; line-height: 1; }

  @media (max-width: 640px) {
    .hero-inner { padding: 22px 18px 70px; } .wm-row { margin-bottom: 28px; }
    .grid { padding: 8px 18px 40px; gap: 16px; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
    .controls { padding: 16px 18px 0; } .meta .src { display: none; }
  }
</style>
